# Django
DJANGO_SECRET_KEY=generate-a-secure-key
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_ALLOWED_HOSTS=.herokuapp.com
DJANGO_ADMIN_URL=admin/
DJANGO_SECURE_SSL_REDIRECT=True

# Database (auto-set by Heroku Postgres addon)
DATABASE_URL=postgres://...

# Redis (auto-set by Heroku Redis addon)
REDIS_URL=redis://...

# Gunicorn
WEB_CONCURRENCY=2

# Optional: S3-compatible object storage (Cloudflare R2 / AWS S3 / Tigris)
# Leave unset to use WhiteNoise for static + ephemeral local media.
# DJANGO_AWS_ACCESS_KEY_ID=
# DJANGO_AWS_SECRET_ACCESS_KEY=
# DJANGO_AWS_STORAGE_BUCKET_NAME=
# DJANGO_AWS_S3_REGION_NAME=auto
# DJANGO_AWS_S3_ENDPOINT_URL=https://xxx.r2.cloudflarestorage.com

# Note: Gemini/OpenAI API keys are configured in Django admin (APISettings model)
